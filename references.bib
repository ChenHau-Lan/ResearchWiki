@article{wuInfluenceMesoscaleTopography2015,
	title = {Influence of {Mesoscale} {Topography} on {Tropical} {Cyclone} {Tracks}: {Further} {Examination} of the {Channeling} {Effect}},
	volume = {72},
	issn = {0022-4928, 1520-0469},
	shorttitle = {Influence of {Mesoscale} {Topography} on {Tropical} {Cyclone} {Tracks}},
	url = {https://journals.ametsoc.org/doi/10.1175/JAS-D-14-0168.1},
	doi = {10.1175/JAS-D-14-0168.1},
	abstract = {Abstract
            Observations have documented typhoons experiencing pronounced track deflection before making landfall in Taiwan. In this study, idealized full-physics model experiments are conducted to assess the orographic influence on tropical cyclone (TC) track. An intense and westward-moving TC is simulated to approach the bell-shaped terrain imitating the Taiwan topography. Sensitivity numerical experiments are carried out to evaluate the topographic effect under different flow regimes and parameters, such as TC intensity, terrain height, and incident angle of the TC movement toward the topography. All the presented simulated storms experience southward track deflection prior to landfall. Different from the mechanism related to the channeling-effect-induced low-level northerly jet as suggested in previous studies, this study indicates the leading role of the northerly asymmetric flow in the midtroposphere in causing the southward deflection of the simulated TC tracks. The midtropospheric northerly asymmetric flow forms as a result of the wind speeds restrained east of the storm center and winds enhanced/maintained west of the storm center. In all, this study highlights a new mechanism that contributes to the terrain-induced southward track deflection in addition to the traditional channeling effect.},
	language = {en},
	number = {8},
	urldate = {2023-03-15},
	journal = {Journal of the Atmospheric Sciences},
	author = {Wu, Chun-Chieh and Li, Tsung-Han and Huang, Yi-Hsuan},
	month = aug,
	year = {2015},
	keywords = {/uncategorized, /unread, tropical cyclone},
	pages = {3032--3050},
}

@article{cione_surface_2000,
	title = {Surface observations in the hurricane environment},
	volume = {128},
	issn = {0027-0644},
	url = {https://www.webofscience.com/wos/woscc/summary/5b80b734-ec18-44fb-a338-f2b1b27779b1-7a00cee8/author-ascending/1},
	doi = {10.1175/1520-0493(2000)128<1550:SOITHE>2.0.CO;2},
	abstract = {Composite analyses of marine surface observations from 37 hurricanes between 1975 and 1998 show that the difference between the sea surface temperature and the surface air temperature significantly increases just outside the hurricane inner core. This increase in the sea-air contrast is primarily due to a reduction in surface air temperature and is more likely to occur when sea temperatures are at least 27 degrees C. Results show that 90\% of the observed cooling occurs 3.25 degrees-1.25 degrees latitude from the hurricane center. well outside the region of strongest surface winds. Since surface pressure only decreases 3 mb over this interval, the similar to 2 degrees C drop in air temperature is not a result of adiabatic expansion. For the subset of observations that contained moisture measurements, surface specific humidity decreased 1.2 g kg(-1) 4.5 degrees-1.75 degrees latitude from the storm center. This Ending suggests that the observed reduction in surface air temperature is not simply a result of near-surface evaporation from sea spray or precipitation. An alternate explanation may be that outside the hurricane inner core, unsaturated convective downdrafts act to dry and evaporatively cool the near-surface environment. Between 3.25 degrees and 1.25 degrees radius, composite analyses show that low-level inflow is not isothermal. surface moisture is not constant, and the near-surface environment is not in thermodynamic equilibrium with the sea. Calculations based on these observations show that theta, decreases between 4.0 degrees and 1.25 degrees radius and then quickly rises near the inner core as surface pressures fall and specific humidity increases. Surface fluxes of heat and moisture are also observed to significantly increase near the inner core. The largest increase in surface sensible heat Aux occurs radially inward of 1.5 degrees. where surface winds are strong and sea-air temperature contrasts are greatest. As a result, the average Bowen ratio is 0.20 similar to 0.5 degrees radius from the composite storm center This increase in sensible heat flux (in conjunction with near-saturated conditions at low to midlevels) may help explain why average surface air temperatures inside 1.25 degrees radius remain relatively constant, despite the potential for additional cooling from evaporation and adiabatic expansion within the high wind inner core.},
	language = {English},
	number = {5},
	urldate = {2023-03-18},
	journal = {Monthly Weather Review},
	publisher = {Amer Meteorological Soc},
	author = {Cione, J. J. and Black, P. G. and Houston, S. H.},
	month = may,
	year = {2000},
	note = {Place: Boston
WOS:000087351800020},
	keywords = {/uncategorized, /unread, tropical cyclone, boundary-layer, mesoscale unsaturated downdrafts, rainband, squall-line, temperature},
	pages = {1550--1561},
}

