{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rkf/topic.schema.json",
  "title": "Topic",
  "type": "object",
  "required": ["topic_id", "name", "scope", "default_search_strings", "review_cadence"],
  "properties": {
    "topic_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "scope": { "type": "string" },
    "include": { "type": "array", "items": { "type": "string" } },
    "exclude": { "type": "array", "items": { "type": "string" } },
    "default_search_strings": { "type": "array", "items": { "type": "string" } },
    "canonical_pages": { "type": "array", "items": { "type": "string" } },
    "review_cadence": { "type": "string" }
  }
}
