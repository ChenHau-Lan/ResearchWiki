{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rkf/source_record.schema.json",
  "title": "SourceRecord",
  "type": "object",
  "required": ["schema", "source_id", "kind", "value", "status", "created", "updated"],
  "properties": {
    "schema": { "const": "rkf-source-record-v1" },
    "source_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$" },
    "kind": { "enum": ["doi", "url", "pdf", "topic", "idea", "question"] },
    "value": { "type": "string", "minLength": 1 },
    "normalized_doi": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "enum": [
        "new",
        "metadata_ok",
        "candidate_found",
        "paper_draft",
        "needs_user_pdf",
        "fulltext_available",
        "reading_in_progress",
        "reading_mature",
        "pdf_checkpoint_required",
        "pdf_downloaded",
        "pdf_qc_needed",
        "pdf_qc_done",
        "wiki_done",
        "abstract_only",
        "blocked"
      ]
    },
    "reading_state": {
      "enum": [
        "metadata-only",
        "abstract-read",
        "partial-fulltext",
        "fulltext-available",
        "fulltext-read",
        "human-reviewed",
        "synthesis-ready",
        "mixed",
        "blocked"
      ]
    },
    "access_state": { "enum": ["metadata", "abstract", "partial", "fulltext"] },
    "review_state": { "enum": ["unread", "skimmed", "read", "annotated", "reproduced"] },
    "fulltext_status": {
      "enum": [
        "unknown",
        "needs-user-pdf",
        "user-pdf-provided",
        "publisher-html",
        "publisher-pdf",
        "open-access-pdf",
        "partial-only",
        "fulltext-read",
        "unavailable",
        "blocked",
        "not-applicable"
      ]
    },
    "topic_ids": { "type": "array", "items": { "type": "string" } },
    "gates": { "type": "array" },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "created": { "type": "string" },
    "updated": { "type": "string" }
  }
}
