{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rkf/rkf_discovery_run.schema.json",
  "title": "RKF Discovery Run",
  "description": "An exact-hash candidate-only discovery record. Acceptance state is stored separately.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "run_id",
    "recorded_at",
    "generated_at",
    "query",
    "topic_id",
    "preview_hash",
    "status",
    "requested_providers",
    "provider_status",
    "candidate_count",
    "candidates",
    "evidence_boundary",
    "promotion"
  ],
  "properties": {
    "schema": {"const": "rkf-discovery-run-v2"},
    "run_id": {"type": "string", "pattern": "^run_[a-z0-9][a-z0-9_-]{0,159}$"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "generated_at": {"type": "string", "format": "date-time"},
    "query": {"type": "string", "minLength": 1, "maxLength": 500},
    "topic_id": {"type": "string", "maxLength": 160},
    "preview_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["ok", "partial", "failed"]},
    "requested_providers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
    },
    "provider_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["provider", "status", "count", "error_code"],
        "properties": {
          "provider": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "status": {"enum": ["ok", "error", "skipped"]},
          "count": {"type": "integer", "minimum": 0},
          "error_code": {
            "enum": ["", "PROVIDER_UNAVAILABLE", "PROVIDER_NOT_CONFIGURED", "OPENALEX_API_KEY_REQUIRED"]
          }
        }
      }
    },
    "candidate_count": {"type": "integer", "minimum": 0},
    "candidates": {
      "type": "array",
      "items": {"$ref": "rkf_discovery_candidate.schema.json"}
    },
    "evidence_boundary": {"const": "candidate-only"},
    "promotion": {"const": "none"}
  }
}
