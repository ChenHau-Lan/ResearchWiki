	keywords = {/uncategorized, /unread},
	pages = {6568},
	file = {Full Text:C\:\\Users\\eric4\\Zotero\\storage\\HUIIGD9C\\Chikamoto et al. - 2017 - Multi-year predictability of climate, drought, and.pdf:application/pdf},
}

