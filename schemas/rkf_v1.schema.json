{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rkf/rkf_v1.schema.json",
  "title": "RKF v1 Canonical Data Model",
  "$defs": {
    "accessState": {"enum": ["metadata", "abstract", "partial", "fulltext"]},
    "reviewState": {"enum": ["unread", "skimmed", "read", "annotated", "reproduced"]},
    "evidenceStance": {"enum": ["supports", "opposes", "contextualizes"]},
    "verificationState": {"enum": ["unreviewed", "human-verified", "rejected"]},
    "claimStatus": {"enum": ["proposed", "supported", "disputed", "verified", "retired"]},
    "readIntent": {"enum": ["digest", "appraise", "both"]},
    "readingScope": {"enum": ["metadata", "abstract", "partial", "fulltext"]},
    "locatorState": {"enum": ["missing", "coarse", "exact"]},
    "providerStatus": {"enum": ["obtained", "manual-required", "retryable", "not-entitled", "unavailable", "blocked", "identity-mismatch", "invalid-artifact", "provider-error"]},
    "identifierType": {"enum": ["doi", "url", "arxiv", "ads-bibcode", "eartharxiv", "osf-preprint", "ess-open-archive", "datacite-doi", "handle", "nasa-ntrs", "noaa-report", "wmo-report", "ipcc-report", "repository", "report"]},
    "artifactVersion": {"enum": ["version-of-record", "accepted-manuscript", "preprint", "unknown"]},
    "artifactQuality": {"enum": ["pending", "readable", "partial", "ocr-required", "corrupt", "identity-mismatch"]},
    "activationMode": {"enum": ["ACTIVE", "ACTIVE_READ_ONLY", "OFF"]},
    "appraisalStatus": {"enum": ["completed", "retryable", "blocked"]},
    "projectId": {"type": "string", "pattern": "^prj_[a-f0-9]{24}$"},
    "activationId": {"type": "string", "pattern": "^act_[a-f0-9]{24}$"},
    "eventId": {"type": "string", "pattern": "^(aevt|actevt)_[a-f0-9]{24}$"},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": {
        "kind": {"enum": ["page", "section", "figure", "table", "paragraph"]},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "paper": {
      "type": "object",
      "required": ["paper_id", "access_state", "review_state"],
      "properties": {
        "paper_id": {"type": "string", "minLength": 1},
        "access_state": {"$ref": "#/$defs/accessState"},
        "review_state": {"$ref": "#/$defs/reviewState"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "finding_id", "paper_id", "summary", "reading_scope", "locator_state", "origin_project_id", "activation_id", "content_fingerprint", "public_safe"],
      "properties": {
        "schema": {"const": "rkf-finding-v1"},
        "finding_id": {"type": "string", "pattern": "^fd_[a-f0-9]{20}$"},
        "paper_id": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "reading_scope": {"$ref": "#/$defs/readingScope"},
        "locator_state": {"$ref": "#/$defs/locatorState"},
        "locator": {"$ref": "#/$defs/locator"},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "content_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "public_safe": {"const": true}
      },
      "allOf": [
        {
          "if": {
            "required": ["locator_state"],
            "properties": {"locator_state": {"const": "missing"}}
          },
          "then": {"not": {"required": ["locator"]}}
        },
        {
          "if": {
            "required": ["locator_state"],
            "properties": {"locator_state": {"enum": ["coarse", "exact"]}}
          },
          "then": {"required": ["locator"]}
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "evidence_id", "paper_id", "locator", "summary", "stance", "verification_state", "reading_scope", "origin_project_id", "activation_id", "content_fingerprint", "public_safe"],
      "properties": {
        "schema": {"const": "rkf-evidence-v1"},
        "evidence_id": {"type": "string", "pattern": "^ev_[a-f0-9]{20}$"},
        "paper_id": {"type": "string", "minLength": 1},
        "locator": {"$ref": "#/$defs/locator"},
        "summary": {"type": "string", "minLength": 1},
        "stance": {"$ref": "#/$defs/evidenceStance"},
        "verification_state": {"$ref": "#/$defs/verificationState"},
        "reading_scope": {"$ref": "#/$defs/readingScope"},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "content_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "public_safe": {"const": true}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "claim_id", "statement", "supporting_evidence_ids", "opposing_evidence_ids", "context_evidence_ids", "status", "origin_project_id", "activation_id", "content_fingerprint", "public_safe"],
      "properties": {
        "schema": {"const": "rkf-claim-v1"},
        "claim_id": {"type": "string", "pattern": "^clm_[a-f0-9]{20}$"},
        "statement": {"type": "string", "minLength": 1},
        "supporting_evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "opposing_evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "context_evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "status": {"$ref": "#/$defs/claimStatus"},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "content_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "public_safe": {"const": true}
      }
    },
    "synthesis": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "synthesis_id", "research_question", "included_claim_ids", "agreements", "contradictions", "evidence_gaps", "origin_project_id", "activation_id", "content_fingerprint", "public_safe"],
      "properties": {
        "schema": {"const": "rkf-synthesis-v1"},
        "synthesis_id": {"type": "string", "pattern": "^syn_[a-f0-9]{20}$"},
        "research_question": {"type": "string", "minLength": 1},
        "included_claim_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "agreements": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "contradictions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "evidence_gaps": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "content_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "public_safe": {"const": true}
      }
    },
    "projectConnection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "project_name", "marker_schema", "connector_version", "connected_at", "status", "paths_redacted"],
      "properties": {
        "project_id": {"$ref": "#/$defs/projectId"},
        "project_name": {"type": "string", "minLength": 1},
        "marker_schema": {"const": "rkf-connect-v2"},
        "connector_version": {"type": "string", "minLength": 1},
        "connected_at": {"type": "string", "format": "date-time"},
        "status": {"enum": ["connected", "blocked", "disconnected"]},
        "paths_redacted": {"const": true}
      }
    },
    "activationEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["activation_id", "project_id", "project_name", "timestamp", "transition", "mode", "paths_redacted"],
      "properties": {
        "activation_id": {"$ref": "#/$defs/activationId"},
        "project_id": {"$ref": "#/$defs/projectId"},
        "project_name": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "format": "date-time"},
        "transition": {"enum": ["started", "closed", "expired", "failed"]},
        "mode": {"$ref": "#/$defs/activationMode"},
        "marker_schema": {"type": "string"},
        "connector_version": {"type": "string"},
        "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "paths_redacted": {"const": true}
      }
    },
    "actionEvent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["event_id", "activation_id", "origin_project_id", "action", "timestamp", "status", "input_fingerprint", "idempotency_key", "affected_object_ids", "promotion", "paths_redacted"],
      "properties": {
        "event_id": {"$ref": "#/$defs/eventId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "action": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "format": "date-time"},
        "status": {"type": "string", "minLength": 1},
        "input_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "idempotency_key": {"type": "string", "minLength": 1},
        "affected_object_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "object_fingerprints": {
          "type": "object",
          "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "promotion": {"type": "string"},
        "paths_redacted": {"const": true}
      }
    },
    "fullTextProviderResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "provider", "provider_version", "elapsed_ms", "tried_routes", "pdf_magic_validated", "blocker_codes", "private_artifact_available"],
      "properties": {
        "status": {"$ref": "#/$defs/providerStatus"},
        "provider": {"type": "string", "minLength": 1},
        "provider_version": {"type": "string", "minLength": 1},
        "route": {"type": "string"},
        "tried_routes": {"type": "array", "items": {"type": "string"}},
        "artifact_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
        "elapsed_ms": {"type": "integer", "minimum": 0},
        "entitlement_state": {"enum": ["unknown", "covered", "not-covered"]},
        "pdf_magic_validated": {"type": "boolean"},
        "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "private_artifact_available": {"type": "boolean"},
        "acquisition_run_id": {"type": "string", "pattern": "^$|^acq_[a-f0-9]{24}$"},
        "identifier_types": {"type": "array", "items": {"$ref": "#/$defs/identifierType"}, "uniqueItems": true},
        "attempts": {"type": "array", "items": {"$ref": "#/$defs/acquisitionAttempt"}},
        "artifact_type": {"type": "string"},
        "artifact_version": {"$ref": "#/$defs/artifactVersion"},
        "artifact_license": {"type": "string"},
        "source_host": {"type": "string"},
        "byte_count": {"type": "integer", "minimum": 0},
        "mime_type": {"type": "string"},
        "quality_state": {"$ref": "#/$defs/artifactQuality"},
        "identity_state": {"enum": ["verified", "unverified", "mismatch"]},
        "page_count": {"type": "integer", "minimum": 0},
        "text_layer_state": {"enum": ["available", "missing", "unknown"]},
        "locator_readiness": {"enum": ["ready", "partial", "not-ready", "unknown"]},
        "related_artifacts": {"type": "array", "items": {"type": "object"}}
      }
    },
    "canonicalIdentifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier_type", "value"],
      "properties": {
        "identifier_type": {"$ref": "#/$defs/identifierType"},
        "value": {"type": "string", "minLength": 1}
      }
    },
    "acquisitionAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "status", "reason_code", "host", "http_status", "elapsed_ms"],
      "properties": {
        "route": {"type": "string", "minLength": 1},
        "status": {"enum": ["resolved", "no-result", "obtained", "manual-required", "retryable", "not-entitled", "unavailable", "blocked", "identity-mismatch", "invalid-artifact", "provider-error"]},
        "reason_code": {"type": "string"},
        "host": {"type": "string"},
        "http_status": {"type": "integer", "minimum": 0},
        "elapsed_ms": {"type": "integer", "minimum": 0}
      }
    },
    "acquisitionRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "acquisition_run_id", "origin_project_id", "activation_id", "source_id", "paper_id", "identifier_fingerprint", "identifier_types", "status", "provider", "provider_version", "selected_route", "attempts", "entitlement_state", "artifact_ids", "blocker_codes", "elapsed_ms", "retry_class", "promotion", "paths_redacted", "public_safe", "created"],
      "properties": {
        "schema": {"const": "rkf-acquisition-run-v1"},
        "acquisition_run_id": {"type": "string", "pattern": "^acq_[a-f0-9]{24}$"},
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "source_id": {"type": "string", "minLength": 1},
        "paper_id": {"type": "string", "minLength": 1},
        "identifier_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "identifier_types": {"type": "array", "items": {"$ref": "#/$defs/identifierType"}, "uniqueItems": true},
        "status": {"$ref": "#/$defs/providerStatus"},
        "provider": {"type": "string", "minLength": 1},
        "provider_version": {"type": "string", "minLength": 1},
        "selected_route": {"type": "string"},
        "attempts": {"type": "array", "items": {"$ref": "#/$defs/acquisitionAttempt"}},
        "entitlement_state": {"enum": ["unknown", "covered", "not-covered"]},
        "artifact_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "blocker_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "elapsed_ms": {"type": "integer", "minimum": 0},
        "retry_class": {"enum": ["none", "serial-retry", "manual"]},
        "promotion": {"const": "none"},
        "paths_redacted": {"const": true},
        "public_safe": {"const": true},
        "created": {"type": "string"}
      }
    },
    "artifactRecord": {
      "type": "object",
      "additionalProperties": true,
      "required": ["artifact_id", "artifact_version", "quality_state", "sha256", "provider", "acquisition_run_id"],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^art_[a-f0-9]{24}$"},
        "artifact_version": {"$ref": "#/$defs/artifactVersion"},
        "quality_state": {"$ref": "#/$defs/artifactQuality"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "provider": {"type": "string", "minLength": 1},
        "acquisition_run_id": {"type": "string", "pattern": "^acq_[a-f0-9]{24}$"}
      }
    },
    "argumentMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paper_id", "evidence_ids", "citation_warnings", "inference_flags", "appraisal_flags"],
      "properties": {
        "paper_id": {"type": "string", "minLength": 1},
        "evidence_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "citation_warnings": {"type": "array", "items": {"type": "object"}},
        "inference_flags": {"type": "array", "items": {"type": "object"}},
        "appraisal_flags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "appraisalProviderResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "provider", "provider_version", "profile", "flags", "warnings", "failures"],
      "properties": {
        "status": {"$ref": "#/$defs/appraisalStatus"},
        "provider": {"type": "string", "minLength": 1},
        "provider_version": {"type": "string", "minLength": 1},
        "profile": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
        "flags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "warnings": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "failures": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "retrievalRun": {
      "type": "object",
      "additionalProperties": true,
      "required": ["retrieval_run_id", "project_id", "activation_id", "query_fingerprint", "provider", "result_object_ids", "paths_redacted"],
      "properties": {
        "retrieval_run_id": {"type": "string", "pattern": "^rrun_[a-f0-9]{24}$"},
        "project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "query_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "provider": {"type": "string", "minLength": 1},
        "provider_version": {"type": "string"},
        "index_generation": {"type": "string"},
        "elapsed_ms": {"type": "integer", "minimum": 0},
        "result_object_ids": {"type": "array", "items": {"type": "string"}},
        "paths_redacted": {"const": true}
      }
    },
    "readRun": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "read_run_id", "paper_id", "intent", "reading_scope", "argument_map", "appraisal", "object_fingerprints", "origin_project_id", "activation_id", "promotion", "public_safe"],
      "properties": {
        "schema": {"const": "rkf-read-run-v1"},
        "read_run_id": {"type": "string", "pattern": "^read_[a-f0-9]{24}$"},
        "paper_id": {"type": "string", "minLength": 1},
        "intent": {"$ref": "#/$defs/readIntent"},
        "reading_scope": {"$ref": "#/$defs/readingScope"},
        "argument_map": {"$ref": "#/$defs/argumentMap"},
        "appraisal": {"$ref": "#/$defs/appraisalProviderResult"},
        "object_fingerprints": {
          "type": "object",
          "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "origin_project_id": {"$ref": "#/$defs/projectId"},
        "activation_id": {"$ref": "#/$defs/activationId"},
        "promotion": {"const": "none"},
        "public_safe": {"const": true}
      }
    }
  }
}
