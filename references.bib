	note = {Place: Boston
WOS:000169996500005},
	keywords = {/uncategorized, /unread, tropical cyclone, evolution, vortex rossby-waves, intensity, potential   vorticity, life-cycle, oceanic cyclogenesis, prediction, storm, system moving offshore},
	pages = {1859--1881},
}

@article{bryan_influence_2009,
	title = {The {Influence} of {Near}-{Surface}, {High}-{Entropy} {Air} in {Hurricane} {Eyes} on {Maximum} {Hurricane} {Intensity}},
	volume = {66},
	issn = {0022-4928},
	url = {https://www.webofscience.com/wos/woscc/summary/5b80b734-ec18-44fb-a338-f2b1b27779b1-7a00cee8/author-ascending/1},
	doi = {10.1175/2008JAS2707.1},
	abstract = {Using a time-dependent axisymmetric numerical model, the authors evaluate whether high-entropy air near the surface in hurricane eyes can substantially increase hurricanes' maximum intensity. This local high-entropy anomaly is ultimately created by surface entropy fluxes in the eye. Therefore, simulations are conducted in which these surface fluxes are set to zero; results show that the high-entropy anomaly is eliminated, yet the axisymmetric tangential wind speed is only slightly weakened (by similar to 4\%, on average). These results contradict the hypothesis that transport of high-entropy air from the eye into the eyewall can significantly increase the maximum axisymmetric intensity of hurricanes. In fact, all simulations (with or without high-entropy anomalies) have an intensity that is 25-30 m s(-1) higher than Emanuel's theoretical maximum intensity. Further analysis demonstrates that less then 3\% of the total surface-entropy input to the hurricane comes from the eye, and therefore the total magnitude of entropy transport between the eye and eyewall is a negligible component of the entropy budget of the simulated hurricanes. This latter finding is consistent with a cursory comparison with observations.},
	language = {English},
	number = {1},
	urldate = {2023-03-18},
	journal = {Journal of the Atmospheric Sciences},
	publisher = {Amer Meteorological Soc},
	author = {Bryan, George H. and Rotunno, Richard},
	month = jan,
	year = {2009},
	note = {Place: Boston
WOS:000262721100010},
	keywords = {/uncategorized, /unread, tropical cyclone, inner-core, convective vertical motions, eyewall, buoyancy, isabel 2003, part ii, potential intensity, sea interaction theory, simulation},
	pages = {148--158},
}

