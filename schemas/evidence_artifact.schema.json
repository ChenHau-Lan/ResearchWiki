{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rkf/evidence_artifact.schema.json",
  "title": "EvidenceArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "evidence_id", "source_id", "artifact_type", "status", "qc_status", "public_safe_pointer"],
  "properties": {
    "schema": { "const": "rkf-evidence-artifact-v1" },
    "evidence_id": { "type": "string" },
    "artifact_id": { "type": "string", "pattern": "^art_[a-f0-9]{24}$" },
    "source_id": {
      "type": "string",
      "description": "Backward-compatible mirror of the source relation used by the latest registration."
    },
    "paper_id": {
      "type": "string",
      "description": "Backward-compatible mirror of the Paper relation used by the latest registration."
    },
    "source_ids": {
      "type": "array",
      "description": "Canonical set of source relations for this checksum-deduplicated artifact.",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "paper_ids": {
      "type": "array",
      "description": "Canonical set of Paper relations for this checksum-deduplicated artifact.",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifact_type": { "enum": ["pdf", "html_snapshot", "screenshot", "metadata", "attachment"] },
    "scientific_artifact_type": {
      "enum": ["pdf", "version-of-record-pdf", "accepted-manuscript", "preprint", "publisher-html", "jats-xml", "supplement", "figure", "table", "dataset-link", "software-link", "correction", "retraction-notice", "report"]
    },
    "artifact_version": { "enum": ["version-of-record", "accepted-manuscript", "preprint", "unknown"] },
    "artifact_license": { "type": "string" },
    "status": { "type": "string" },
    "qc_status": { "enum": ["not_started", "pending", "codex_qc_done", "human_qc_done", "failed"] },
    "quality_state": { "enum": ["pending", "readable", "partial", "ocr-required", "corrupt", "identity-mismatch"] },
    "identity_state": { "enum": ["verified", "unverified", "mismatch"] },
    "page_count": { "type": "integer", "minimum": 0 },
    "text_layer_state": { "enum": ["available", "missing", "unknown"] },
    "locator_readiness": { "enum": ["ready", "partial", "not-ready", "unknown"] },
    "storage_path": { "type": "string" },
    "public_safe_pointer": { "type": "string" },
    "authorized_route": { "type": "string" },
    "locators": { "type": "array", "items": { "type": "string" } },
    "qc_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "note"],
        "properties": {
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "byte_count": { "type": "integer", "minimum": 0 },
    "mime_type": { "type": "string" },
    "provider": { "type": "string" },
    "provider_version": { "type": "string" },
    "route": { "type": "string" },
    "source_host": { "type": "string" },
    "acquisition_run_id": { "type": "string", "pattern": "^$|^acq_[a-f0-9]{24}$" },
    "related_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relationship", "artifact_type", "host", "identifier"],
        "properties": {
          "relationship": { "type": "string" },
          "artifact_type": { "type": "string" },
          "host": { "type": "string" },
          "identifier": { "type": "string" }
        }
      }
    },
    "readability_state": { "enum": ["unreviewed", "readable", "unreadable"] },
    "locator_state": { "enum": ["unreviewed", "available", "missing"] },
    "origin_project_id": { "type": "string", "pattern": "^prj_[a-f0-9]{24}$" },
    "activation_id": { "type": "string", "pattern": "^act_[a-f0-9]{24}$" },
    "public_safe": { "const": true },
    "created": { "type": "string" },
    "updated": { "type": "string" }
  }
}
